{
  "name": "stoa",
  "version": "0.3.0",
  "description": "Multi-agent swarm framework. Seven autonomous agents coordinate via GitHub Actions — trading, research, content, social, devops, and automation.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stoa": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "dispatch": "tsx src/dispatch.ts",
    "execute": "tsx src/execute.ts",
    "tick": "tsx src/dispatch.ts",
    "chain": "tsx src/chain-cli.ts",
    "validate": "tsx src/validate-config.ts",
    "lint": "eslint 'src/**/*.ts' --max-warnings 0",
    "lint:fix": "eslint 'src/**/*.ts' --fix",
    "test": "tsx test-pipeline.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "solana",
    "ai-agent",
    "swarm",
    "multi-agent",
    "framework",
    "autonomous",
    "defi",
    "claude-code",
    "self-healing"
  ],
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "yaml": "^2.4.0",
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "tsx": "^4.16.0",
    "@types/node": "^20.14.0",
    "eslint": "^9.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/",
    "agents/",
    "skills/",
    "memory/",
    "stoa.yml",
    "CLAUDE.md"
  ]
}
